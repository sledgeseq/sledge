# filter_test.config — DB_FILE and FIXED_FILE are passed on the command line (--db-file, --fixed-file).
# test_installation.sh rewrites OUT_DIR, SLEDGE_FILTER, MMSEQS, BLAST_DIR, and FASTA_DIR via write_filter_config_to() for portable runs.

# --- Directories (input files come from CLI) ---
OUT_DIR="check"

# --- Keep intermediate files (TSV hit files, etc.); set to 1 to retain, empty to delete ---
KEEP_INTERMEDIATES="1"

# --- Task/shard ID (e.g. for SLURM array jobs, set to SLURM_ARRAY_TASK_ID) ---
TASK_ID="0"

# --- Remove sequences from "db" (filter DB_FILE through pipeline) or "fixed" (filter FIXED_FILE) ---
REMOVE_TARGET="db"

# --- Long ID parsing: set to 1 if FASTA headers use pipe-separated IDs and you want the 2nd field ---
USE_LONG_ID="1"

# --- E-value threshold (used by phmmer, mmseqs, blast, sw) and database size Z ---
E_VALUE="0.01"
Z_SIZE="100"

# --- Cores per tool (can be set differently for each) ---
SLEDGE_CORES="1"
MMSEQS_CORES="1"
BLAST_CORES="1"
SW_CORES="1"

# --- Tool binaries / directories ---
PHMMER_FILTER="/n/eddy_lab/Lab/protein_annotation_dl/sledge/bin/phmmer_filter"
MMSEQS="/n/eddy_lab/Lab/protein_annotation_dl/mmseqs/bin/mmseqs"
BLAST_DIR="/n/eddy_lab/Lab/protein_annotation_dl/ncbi-blast-2.15.0+/bin"
FASTA_DIR="/n/eddy_lab/Lab/protein_annotation_dl/fasta36/bin"

# --- BLAST dbsize (for E-value calculation) ---
BLAST_DBSIZE="3000"

# --- MMseqs / BLAST limits ---
MMSEQS_MAX_SEQS="100"
BLAST_MAX_TARGET_SEQS="100"
